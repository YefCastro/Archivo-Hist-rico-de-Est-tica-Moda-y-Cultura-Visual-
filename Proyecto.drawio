        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n\n\nskinparam backgroundColor transparent\nskinparam shadowing false\nskinparam roundcorner 8\nskinparam linetype ortho\nskinparam defaultFontName Arial\n\n!theme plain\n\nentity \&quot;USUARIO\&quot; as USUARIO {\n  +id_usuario : int &lt;&lt;PK&gt;&gt;\n  --\n  nombre : string\n  email : string\n  rol : string\n}\n\n\nentity \&quot;CONSULTA\&quot; as CONSULTA {\n  +id_consulta : int &lt;&lt;PK&gt;&gt;\n  --\n  id_usuario : int &lt;&lt;FK&gt;&gt;\n  texto_pregunta : string\n  fecha : timestamp\n}\n\n\nentity \&quot;QUERY_EMBEDDING\&quot; as QUERY_EMBEDDING {\n  +id_qemb : int &lt;&lt;PK&gt;&gt;\n  --\n  id_consulta : int &lt;&lt;FK&gt;&gt;\n  vector_embedding : float[]\n  modelo : string\n}\n\n\nentity \&quot;RESULTADO\&quot; as RESULTADO {\n  +id_resultado : int &lt;&lt;PK&gt;&gt;\n  --\n  id_consulta : int &lt;&lt;FK&gt;&gt;\n  score_similitud : float\n}\n\n\nentity \&quot;RESULTADO_DOCUMENTO\&quot; as RESULTADO_DOCUMENTO {\n  +id_resultado : int &lt;&lt;FK&gt;&gt;\n  +id_doc : int &lt;&lt;FK&gt;&gt;\n  --\n  &lt;&lt;PK&gt;&gt; (id_resultado, id_doc)\n}\n\n\nentity \&quot;RESULTADO_IMAGEN\&quot; as RESULTADO_IMAGEN {\n  +id_resultado : int &lt;&lt;FK&gt;&gt;\n  +id_img : int &lt;&lt;FK&gt;&gt;\n  --\n  &lt;&lt;PK&gt;&gt; (id_resultado, id_img)\n}\n\n\nentity \&quot;EVALUACION\&quot; as EVALUACION {\n  +id_eval : int &lt;&lt;PK&gt;&gt;\n  --\n  id_consulta : int &lt;&lt;FK&gt;&gt;\n  faithfulness : float\n  answer_relevancy : float\n  context_recall : float\n  modelo_eval : string\n  fecha : timestamp\n}\n\n\nentity \&quot;DOCUMENTO\&quot; as DOCUMENTO {\n  +id_doc : int &lt;&lt;PK&gt;&gt;\n  --\n  titulo : string\n  idioma : string\n  fecha : date\n  fuente : string\n  contenido_texto : text\n}\n\n\nentity \&quot;IMAGEN\&quot; as IMAGEN {\n  +id_img : int &lt;&lt;PK&gt;&gt;\n  --\n  id_doc : int &lt;&lt;FK&gt;&gt;\n  ruta_archivo : string\n  descripcion : string\n  etiquetas : string\n}\n\n\nentity \&quot;EMBEDDING_TEXTO\&quot; as EMBEDDING_TEXTO {\n  +id_embedding : int &lt;&lt;PK&gt;&gt;\n  --\n  id_doc : int &lt;&lt;FK&gt;&gt;\n  chunk_id : int\n  estrategia_chunking : string\n  vector_embedding : float[]\n  modelo : string\n}\n\n\nentity \&quot;EMBEDDING_IMAGEN\&quot; as EMBEDDING_IMAGEN {\n  +id_embedding : int &lt;&lt;PK&gt;&gt;\n  --\n  id_img : int &lt;&lt;FK&gt;&gt;\n  vector_embedding : float[]\n  modelo : string\n}\n\n\n\nUSUARIO ||--o{ CONSULTA : realiza\n\nCONSULTA ||--|| QUERY_EMBEDDING : vectoriza\nCONSULTA ||--o{ RESULTADO : produce\nCONSULTA ||--o| EVALUACION : evalua\n\nDOCUMENTO ||--o{ IMAGEN : contiene\nDOCUMENTO ||--o{ EMBEDDING_TEXTO : fragmenta\n\nIMAGEN ||--|| EMBEDDING_IMAGEN : genera\n\n\n\nRESULTADO ||--o{ RESULTADO_DOCUMENTO\nDOCUMENTO ||--o{ RESULTADO_DOCUMENTO\n\nRESULTADO ||--o{ RESULTADO_IMAGEN\nIMAGEN ||--o{ RESULTADO_IMAGEN\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="UAwqeNbwH8ixnHib6lXS-689">
